# Copy to .env.stateless, then run:
#   docker compose -f docker-compose.stateless.yaml --env-file .env.stateless up
#
# This stack mirrors the production deployment at
# source/repos/do/gitlab/gitlab-mcp — same auth mode (GITLAB_MCP_OAUTH
# with callback-proxy), same upstream GitLab contract — but uses
# stateless mode to remove the need for Traefik cookie stickiness.

# ============================================================================
# Image
# ============================================================================

# Default is the GHCR tag published by this repo's CI. For an immutable
# reference, point at a specific commit SHA (the GHCR workflow tags every
# build with its 40-char SHA).
#GITLAB_MCP_IMAGE=ghcr.io/fabiogermann/gitlab-mcp:latest

# ============================================================================
# Stateless mode (REQUIRED)
# ============================================================================

# Shared 32-byte base64url secret. Generate a fresh one:
#   openssl rand -base64 32
# BOTH containers must receive the same value.
OAUTH_STATELESS_SECRET=REPLACE_ME_WITH_32_BYTES_BASE64URL

# Optional previous-slot secret for rotation tests. Leave empty normally.
OAUTH_STATELESS_SECRET_PREVIOUS=

# ============================================================================
# GitLab MCP OAuth proxy (REQUIRED — matches production)
# ============================================================================

# Upstream GitLab API base URL. Match the self-hosted GitLab you own the
# OAuth app in. Examples:
#   https://gitserver.warrantymaster.com/api/v4   (ScalePad production)
#   https://gitlab.com/api/v4                     (gitlab.com)
GITLAB_API_URL=https://gitserver.warrantymaster.com/api/v4

# Public URL of the MCP endpoint as the MCP client sees it. In this
# compose it's the round-robin load balancer at port 3000. For a real
# deployment behind Traefik this would be https://gitlab.mcp.scalepad.sh.
MCP_SERVER_URL=http://127.0.0.1:3000

# Pre-registered GitLab OAuth application client_id. Must have:
#   - redirect URI = ${MCP_SERVER_URL}/callback
#   - scopes = api (rw) or read_api (ro)
#   - Confidential unchecked (public client; PKCE replaces client_secret)
GITLAB_OAUTH_APP_ID=REPLACE_ME_WITH_GITLAB_OAUTH_APP_ID

# Optional GitLab scope override; comma-separated. Defaults to "api"
# (or "read_api" when GITLAB_READ_ONLY_MODE=true).
#GITLAB_OAUTH_SCOPES=api,read_user

# MCP_SERVER_URL above uses http:// for local smoke testing. The server
# normally refuses to run with a non-HTTPS issuer URL on a non-loopback
# host. Set this to true to override during local testing ONLY. Remove
# for any real deployment.
MCP_DANGEROUSLY_ALLOW_INSECURE_ISSUER_URL=true

# ============================================================================
# Behaviour
# ============================================================================

# Read-only is safer for smoke testing against production GitLab.
GITLAB_READ_ONLY_MODE=true

# Use debug to see one "stateless /mcp request" log line per request.
LOG_LEVEL=info
